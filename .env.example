# === 登入密碼 ===
SITE_PASSWORD=your_strong_password_here

# === JWT 簽章金鑰（隨便輸入一串長的英數字，至少 32 字元）===
JWT_SECRET=please_change_this_to_a_random_long_string_at_least_32_chars

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-1001234567890

# === 平台 API ===
SITE_API_BASE=https://your-platform.com/api
SITE_API_KEY=your_agent_api_key
SITE_USERNAME=your_agent_username
SITE_PASSWORD_PLATFORM=your_agent_password

# === Cron 端點驗證密鑰（隨機字串）===
CRON_SECRET=another_random_secret_string

# === Vercel KV（連結 KV 後 Vercel 會自動填入）===
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
